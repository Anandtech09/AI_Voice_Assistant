# ============================================
# AI Voice Agent - Environment Variables Template
# ============================================

GEMINI_API_KEY=

# Twilio Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Phone Number (the number Twilio assigns you)
TWILIO_PHONE_NUMBER=

# Your Phone Number (the number to call)
YOUR_PHONE_NUMBER=

# ngrok Public URL (update each time you restart ngrok)
NGROK_URL=

# Server Configuration
HOST=0.0.0.0
PORT=8000
